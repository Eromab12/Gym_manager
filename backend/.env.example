# Variables de entorno para el backend de Gym Manager App
# Copia este archivo a .env y remplaza los valores con tus credenciales reales

# Puerto del servidor (en Render se asigna automáticamente)
PORT=5000

# URI de conexión a MongoDB
MONGODB_URI=mongodb://localhost:27017/app_gym

# Credenciales de Cloudinary (para almacenamiento de imágenes)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Otras variables de entorno según necesites
# JWT_SECRET=your_jwt_secret_here
# NODE_ENV=development